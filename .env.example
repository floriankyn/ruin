# Postgres
POSTGRES_USER=ruin
POSTGRES_PASSWORD=ruin_password

# Keycloak admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Database (app)
DATABASE_URL=postgresql://ruin:ruin_password@localhost:5432/ruin

# Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here

AUTH_KEYCLOAK_ID=ruin-client
AUTH_KEYCLOAK_SECRET=ruin-dev-secret
AUTH_KEYCLOAK_ISSUER=http://localhost:8080/realms/ruin
AUTH_URL=http://localhost:3000